    m_PersistentCalls:
      m_Calls: []
  m_text: "\u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0439 \u0448\u0442\u0440\u0438\u0445
    \u2014 \u0441\u0442\u0430\u0432\u0438\u043C \u043D\u0430\u043A\u043E\u043F\u0438\u0442\u0435\u043B\u0438.
    \u0412 \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0439 \u0441\u0431\u043E\u0440\u043A\u0435
    \u0442\u044B \u0431\u044B \u0437\u0430\u043A\u0440\u0435\u043F\u0438\u043B 3.5\"
    HDD \u0432 \u043A\u043E\u0440\u0437\u0438\u043D\u0435 \u0432\u0438\u043D\u0442\u0430\u043C\u0438,
    2.5\" SSD \u043F\u0440\u0438\u043A\u0440\u0443\u0442\u0438\u043B \u043A \u043F\u043B\u043E\u0449\u0430\u0434\u043A\u0435
    \u0441\u0437\u0430\u0434\u0438, \u0430 M.2 NVMe \u0432\u0441\u0442\u0430\u0432\u0438\u043B
    \u0432 \u0441\u043B\u043E\u0442 \u043F\u043E\u0434 \u0443\u0433\u043B\u043E\u043C
    30\xB0, \u043E\u043F\u0443\u0441\u0442\u0438\u043B \u0438 \u0437\u0430\u043A\u0440\u0443\u0442\u0438\u043B
    \u0432\u0438\u043D\u0442\u0438\u043A. \u0412 \u0438\u0433\u0440\u0435 \u2014
    \u043F\u0440\u043E\u0441\u0442\u043E \u043F\u0435\u0440\u0435\u0442\u0430\u0449\u0438
    \u043D\u0430\u043A\u043E\u043F\u0438\u0442\u0435\u043B\u0438 \u0432 \u043A\u043E\u0440\u0437\u0438\u043D\u0443
    \u0432 \u043A\u043E\u0440\u043F\u0443\u0441\u0435.\n"
