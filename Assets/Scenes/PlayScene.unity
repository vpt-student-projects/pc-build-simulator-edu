  m_text: "\u0412 \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438: \u0432\u0441\u0435\u0433\u0434\u0430
    \u0441\u0442\u0430\u0432\u044C \u0434\u0432\u0435 \u043F\u043B\u0430\u043D\u043A\u0438
    \u0432 \u0441\u043B\u043E\u0442\u044B \u043E\u0434\u043D\u043E\u0433\u043E \u0446\u0432\u0435\u0442\u0430
    (\u043E\u0431\u044B\u0447\u043D\u043E 2-\u0439 \u0438 4-\u0439 \u043E\u0442 \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u043E\u0440\u0430)
    \u2014 \u044D\u0442\u043E \u0430\u043A\u0442\u0438\u0432\u0438\u0440\u0443\u0435\u0442
    \u0434\u0432\u0443\u0445\u043A\u0430\u043D\u0430\u043B\u044C\u043D\u044B\u0439
    \u0440\u0435\u0436\u0438\u043C \u0438 \u0434\u0430\u0451\u0442 +10-15% \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438."
