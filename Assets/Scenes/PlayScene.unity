  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0421\u0430\u043C\u044B\u0439 \u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u0448\u0430\u0433. \u0412 \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0439 \u0441\u0431\u043E\u0440\u043A\u0435
    \u0442\u044B \u0431\u044B \u0430\u043A\u043A\u0443\u0440\u0430\u0442\u043D\u043E
    \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u0438\u043B \u0437\u043E\u043B\u043E\u0442\u043E\u0439
    \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A \u043D\u0430
    \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u043E\u0440\u0435 \u0441 \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u043E\u043C
    \u043D\u0430 \u0441\u043E\u043A\u0435\u0442\u0435, \u043E\u043F\u0443\u0441\u0442\u0438\u043B
    \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u043E\u0440 \u0441\u0442\u0440\u043E\u0433\u043E
    \u0432\u0435\u0440\u0442\u0438\u043A\u0430\u043B\u044C\u043D\u043E (\u043D\u0435
    \u0440\u043E\u043D\u044F\u044F!) \u0438 \u0437\u0430\u0449\u0451\u043B\u043A\u043D\u0443\u043B
    \u0440\u044B\u0447\u0430\u0433. \u0412 \u0438\u0433\u0440\u0435 \u2014 \u043F\u0440\u043E\u0441\u0442\u043E
    \u043F\u0435\u0440\u0435\u0442\u0430\u0449\u0438 \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u043E\u0440
    \u043D\u0430 \u0441\u043E\u043A\u0435\u0442.\n"
