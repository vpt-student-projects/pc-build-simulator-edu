  m_text: "\u0421\u0442\u0430\u0432\u0438\u043C \u043C\u0430\u0442\u0435\u0440\u0438\u043D\u0441\u043A\u0443\u044E
    \u043F\u043B\u0430\u0442\u0443 \u0432 \u043A\u043E\u0440\u043F\u0443\u0441. \u0412
    \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0439 \u0441\u0431\u043E\u0440\u043A\u0435
    \u0442\u044B \u0431\u044B \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u0438\u043B
    \u043E\u0442\u0432\u0435\u0440\u0441\u0442\u0438\u044F \u043F\u043B\u0430\u0442\u044B
    \u0441\u043E \u0441\u0442\u043E\u0439\u043A\u0430\u043C\u0438 \u043A\u043E\u0440\u043F\u0443\u0441\u0430
    \u0438 \u0437\u0430\u043A\u0440\u0443\u0442\u0438\u043B 6\u20139 \u0432\u0438\u043D\u0442\u043E\u0432.
    \u0412 \u043D\u0430\u0448\u0435\u0439 \u0438\u0433\u0440\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u043F\u0435\u0440\u0435\u0442\u0430\u0449\u0438 \u043F\u043B\u0430\u0442\u0443
    \u043D\u0430 \u043C\u0435\u0441\u0442\u043E \u0433\u0434\u0435 \u0434\u043E\u043B\u0436\u043D\u0430
    \u0431\u044B\u0442\u044C \u043F\u043B\u0430\u0442\u0430 \u2014 \u043E\u043D\u0430
    \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0432\u0441\u0442\u0430\u043D\u0435\u0442 \u043A\u0430\u043A \u043D\u0430\u0434\u043E."
