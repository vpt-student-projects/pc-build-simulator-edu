  m_text: "\u0412 \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438: \u043D\u0438
    \u0432 \u043A\u043E\u0435\u043C \u0441\u043B\u0443\u0447\u0430\u0435 \u043D\u0435
    \u0442\u0440\u043E\u0433\u0430\u0439 \u043D\u043E\u0436\u043A\u0438 \u0441\u043E\u043A\u0435\u0442\u0430
    (LGA) \u0438 \u043A\u043E\u043D\u0442\u0430\u043A\u0442\u043D\u044B\u0435 \u043F\u043B\u043E\u0449\u0430\u0434\u043A\u0438
