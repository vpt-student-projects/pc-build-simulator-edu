  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u041D\u0430\u0447\u043D\u0438 \u0441 \u043F\u0443\u0441\u0442\u043E\u0433\u043E
    \u043A\u043E\u0440\u043F\u0443\u0441\u0430. \u0412 \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0439
    \u0441\u0431\u043E\u0440\u043A\u0435 \u0442\u044B \u0431\u044B \u0441\u043D\u044F\u043B
    \u043E\u0431\u0435 \u0431\u043E\u043A\u043E\u0432\u044B\u0435 \u043A\u0440\u044B\u0448\u043A\u0438,
    \u043E\u0442\u043A\u0440\u0443\u0442\u0438\u0432 \u0432\u0438\u043D\u0442\u044B
    \u0441\u0437\u0430\u0434\u0438, \u0438 \u0443\u0431\u0440\u0430\u043B \u043A\u0430\u0431\u0435\u043B\u044C-\u043C\u0435\u043D\u0435\u0434\u0436\u043C\u0435\u043D\u0442.
    \u0412 \u043D\u0430\u0448\u0435\u0439 \u0438\u0433\u0440\u0435 \u043A\u043E\u0440\u043F\u0443\u0441
    \u0443\u0436\u0435 \u0433\u043E\u0442\u043E\u0432 \u043A \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0435
    \u2014 \u043F\u0440\u043E\u0441\u0442\u043E \u043F\u0435\u0440\u0435\u0442\u0430\u0449\u0438
    \u0435\u0433\u043E \u043D\u0430 \u0440\u0430\u0431\u043E\u0447\u0435\u0435 \u043F\u043E\u043B\u0435,
    \u0438 \u043F\u043E\u0435\u0445\u0430\u043B\u0438.\r\n\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
