  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0421\u0442\u0430\u0432\u0438\u043C \u043E\u0445\u043B\u0430\u0436\u0434\u0435\u043D\u0438\u0435
    \u043D\u0430 \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u043E\u0440. \u0412 \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0439
    \u0441\u0431\u043E\u0440\u043A\u0435 \u0442\u044B \u0431\u044B \u0441\u043D\u044F\u043B
    \u0437\u0430\u0449\u0438\u0442\u043D\u0443\u044E \u043F\u043B\u0451\u043D\u043A\u0443
    \u0441 \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044F \u043A\u0443\u043B\u0435\u0440\u0430,
    \u043D\u0430\u043D\u0451\u0441 \u0442\u0435\u0440\u043C\u043E\u043F\u0430\u0441\u0442\u0443
    (\u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0443\u044E \u0433\u043E\u0440\u043E\u0448\u0438\u043D\u0443),
    \u043F\u0440\u0438\u043A\u0440\u0443\u0442\u0438\u043B \u043A\u0443\u043B\u0435\u0440
    \u043A \u043A\u0440\u0435\u043F\u043B\u0435\u043D\u0438\u044F\u043C \u0432\u043E\u043A\u0440\u0443\u0433
    \u0441\u043E\u043A\u0435\u0442\u0430 \u043A\u0440\u0435\u0441\u0442-\u043D\u0430\u043A\u0440\u0435\u0441\u0442
    \u0438 \u043F\u043E\u0434\u043A\u043B\u044E\u0447\u0438\u043B \u043F\u0440\u043E\u0432\u043E\u0434
    \u0432\u0435\u043D\u0442\u0438\u043B\u044F\u0442\u043E\u0440\u0430 \u043A \u0440\u0430\u0437\u044A\u0451\u043C\u0443
    CPU_FAN. \u0412 \u0438\u0433\u0440\u0435 \u2014 \u043F\u0440\u043E\u0441\u0442\u043E
    \u043F\u0435\u0440\u0435\u0442\u0430\u0449\u0438 \u043A\u0443\u043B\u0435\u0440
    \u043D\u0430 \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u043E\u0440.\n"
