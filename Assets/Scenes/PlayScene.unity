      m_Calls: []
  m_text: "\u0421\u0442\u0430\u0432\u0438\u043C \u043F\u043B\u0430\u043D\u043A\u0438
    \u041E\u0417\u0423. \u0412 \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0439 \u0441\u0431\u043E\u0440\u043A\u0435
    \u0442\u044B \u0431\u044B \u043E\u0442\u0449\u0451\u043B\u043A\u043D\u0443\u043B
    \u0437\u0430\u0436\u0438\u043C\u044B \u043D\u0430 \u0441\u043B\u043E\u0442\u0430\u0445,
    \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u0438\u043B \u043A\u043B\u044E\u0447-\u043F\u0440\u043E\u0440\u0435\u0437\u044C
    \u043D\u0430 \u043F\u043B\u0430\u043D\u043A\u0435 \u0441 \u0432\u044B\u0441\u0442\u0443\u043F\u043E\u043C
    \u0432 \u0441\u043B\u043E\u0442\u0435 \u0438 \u043D\u0430\u0434\u0430\u0432\u0438\u043B
    \u0441 \u0434\u0432\u0443\u0445 \u0441\u0442\u043E\u0440\u043E\u043D \u0434\u043E
    \u0449\u0435\u043B\u0447\u043A\u0430. \u0412 \u0438\u0433\u0440\u0435 \u2014
    \u043F\u0440\u043E\u0441\u0442\u043E \u043F\u0435\u0440\u0435\u0442\u0430\u0449\u0438
    \u043F\u043B\u0430\u043D\u043A\u0438 \u043D\u0430 \u0441\u043B\u043E\u0442\u044B
    \u043C\u0430\u0442\u0435\u0440\u0438\u043D\u0441\u043A\u043E\u0439 \u043F\u043B\u0430\u0442\u044B.\n"
