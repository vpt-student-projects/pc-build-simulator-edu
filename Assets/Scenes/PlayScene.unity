  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0421\u0442\u0430\u0432\u0438\u043C \u0432\u0438\u0434\u0435\u043E\u043A\u0430\u0440\u0442\u0443
    \u0432 \u0432\u0435\u0440\u0445\u043D\u0438\u0439 \u0441\u043B\u043E\u0442 PCIe
    x16. \u0412 \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0439 \u0441\u0431\u043E\u0440\u043A\u0435
    \u0442\u044B \u0431\u044B \u0441\u043D\u044F\u043B \u0437\u0430\u0433\u043B\u0443\u0448\u043A\u0438
    \u0441 \u0437\u0430\u0434\u043D\u0435\u0439 \u043F\u0430\u043D\u0435\u043B\u0438
    \u043A\u043E\u0440\u043F\u0443\u0441\u0430, \u043E\u0442\u0449\u0451\u043B\u043A\u043D\u0443\u043B
    \u0437\u0430\u0436\u0438\u043C \u043D\u0430 \u0441\u043B\u043E\u0442\u0435, \u0432\u0441\u0442\u0430\u0432\u0438\u043B
    \u043A\u0430\u0440\u0442\u0443 \u0434\u043E \u0449\u0435\u043B\u0447\u043A\u0430
    \u0438 \u0437\u0430\u043A\u0440\u0435\u043F\u0438\u043B \u0432\u0438\u043D\u0442\u043E\u043C.
    \u0412 \u0438\u0433\u0440\u0435 \u2014 \u043F\u0440\u043E\u0441\u0442\u043E \u043F\u0435\u0440\u0435\u0442\u0430\u0449\u0438
    \u0432\u0438\u0434\u0435\u043E\u043A\u0430\u0440\u0442\u0443 \u043D\u0430 \u043C\u0430\u0442\u0435\u0440\u0438\u043D\u0441\u043A\u0443\u044E
    \u043F\u043B\u0430\u0442\u0443.\n"
