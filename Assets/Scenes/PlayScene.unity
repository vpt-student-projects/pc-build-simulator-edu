  m_text: "\u0412 \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438: \u043D\u0430
    \u044D\u0442\u043E\u043C \u044D\u0442\u0430\u043F\u0435 \u043D\u0435 \u043F\u043E\u0434\u043A\u043B\u044E\u0447\u0430\u0439
    \u043A\u0430\u0431\u0435\u043B\u0438 \u2014 \u043E\u0441\u0442\u0430\u0432\u044C
    \u0438\u0445 \u0441\u0432\u0438\u0441\u0430\u0442\u044C \u0441\u0437\u0430\u0434\u0438.
    \u041F\u043E\u0434\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0435\u043C \u0437\u0430\u0439\u043C\u0451\u043C\u0441\u044F,
    \u043A\u043E\u0433\u0434\u0430 \u0432\u0441\u0451 \u0431\u0443\u0434\u0435\u0442
    \u043D\u0430 \u0441\u0432\u043E\u0438\u0445 \u043C\u0435\u0441\u0442\u0430\u0445."
