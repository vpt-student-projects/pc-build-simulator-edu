      m_Calls: []
  m_text: "\u0411\u043B\u043E\u043A \u043F\u0438\u0442\u0430\u043D\u0438\u044F \u043E\u0431\u044B\u0447\u043D\u043E
    \u0441\u0442\u0430\u0432\u0438\u0442\u0441\u044F \u0432 \u043D\u0438\u0436\u043D\u044E\u044E
    \u0447\u0430\u0441\u0442\u044C \u043A\u043E\u0440\u043F\u0443\u0441\u0430 \u0432\u0435\u043D\u0442\u0438\u043B\u044F\u0442\u043E\u0440\u043E\u043C
    \u0432\u043D\u0438\u0437 (\u0435\u0441\u043B\u0438 \u043A\u043E\u0440\u043F\u0443\u0441
    \u0441 \u043D\u0438\u0436\u043D\u0438\u043C \u043F\u0440\u043E\u0434\u0443\u0432\u043E\u043C).
    \u0412 \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0439 \u0441\u0431\u043E\u0440\u043A\u0435
    \u0442\u044B \u0431\u044B \u0437\u0430\u043A\u0440\u0435\u043F\u0438\u043B \u0435\u0433\u043E
    \u0447\u0435\u0442\u044B\u0440\u044C\u043C\u044F \u0432\u0438\u043D\u0442\u0430\u043C\u0438
    \u0441\u0437\u0430\u0434\u0438 \u043A\u043E\u0440\u043F\u0443\u0441\u0430. \u0412
    \u0438\u0433\u0440\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043F\u0435\u0440\u0435\u0442\u0430\u0449\u0438
    \u0411\u041F \u043D\u0430 \u043A\u043E\u0440\u043F\u0443\u0441.\r\n\r\n"
